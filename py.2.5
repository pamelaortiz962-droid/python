secreto = 7

numero = int(input("Adivina el número secreto: "))

while numero != secreto:
    if numero < secreto:
        print("El número secreto es mayor")
    else:
        print("El número secreto es menor")

    numero = int(input("Intenta otra vez -.-: "))

print("¡Correcto :D! Adivinaste el número")
